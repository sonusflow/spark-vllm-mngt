# vLLM Manager — Connection Settings
# Fill in your DGX Spark details below.

# DGX Spark IP address or hostname
SPARK_HOST="YOUR_DGX_IP"

# SSH username on the DGX Spark
SPARK_USER="YOUR_USERNAME"

# Path to spark-vllm-docker repo on the DGX Spark
SPARK_VLLM_DIR="/home/YOUR_USERNAME/spark-vllm-docker"

# SSH options (adjust as needed)
SSH_OPTS="-o ConnectTimeout=10 -o StrictHostKeyChecking=no"

# vLLM API port (default 8000)
VLLM_PORT="8000"
